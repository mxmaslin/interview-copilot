# Скопируй: cp .env.example .env

# --- Ключи ---
# https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_...
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Скриншоты (vision), опционально для ⌘↩:
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# --- Ответ на вопрос (⌘↩) ---
# deepseek | openai | cursor
ANSWER_PROVIDER=deepseek
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# OPENAI_ANSWER_MODEL=gpt-4o-mini
# ANSWER_MAX_TOKENS=450
# ANSWER_REQUEST_TIMEOUT=120

TERMINAL_ANSWER_STREAM=1
TERMINAL_SHOW_INTERVIEWER=1
TERMINAL_SHOW_SELF=1

# 0 = вопрос + контекст диалога (рекомендуется); 1 = только последний вопрос
# ANSWER_MINIMAL_CONTEXT=0

# ANSWER_SELF_QUESTIONS=auto
# ANSWER_INTERVIEWER_MERGE_MAX=2
# ANSWER_SELF_MERGE_MAX=1   # >1 — склеить паузы одной фразы; не для серии разных вопросов
ANSWER_AUTO=1
# ANSWER_AUTO_DELAY_SEC=0.2   # 0 = сразу после STT; ⌘↩ всегда немедленно
# CALL_MIC_MUTED=0

# Cursor SDK (⌘↩ при ANSWER_PROVIDER=cursor; скрины — см. ниже)
# CURSOR_MODEL=auto
# CURSOR_ANSWER_CONTEXT_CHARS=800
# CURSOR_ANSWER_MINIMAL=0
# CURSOR_OPEN_ANSWER_FILE=0
# CURSOR_AGENT_MIRROR=0
# CURSOR_AGENT_CHAT_ID=   # UUID чата после New Agent в Cursor

# --- Скриншот ⌘⌃⇧4 (docs/screenshot-solve.md) ---
# deepseek-chat без vision → нужен CURSOR_API_KEY или SCREENSHOT_ANSWER_PROVIDER
SCREENSHOT_SOLVE_ENABLED=1
# cursor | openai | anthropic
# SCREENSHOT_ANSWER_PROVIDER=cursor
# SCREENSHOT_ANSWER_PROVIDER=anthropic
# SCREENSHOT_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# SCREENSHOT_OPENAI_MODEL=gpt-4o-mini
# SCREENSHOT_CURSOR_MODEL=auto
# SCREENSHOT_REUSE_AGENT=1
# SCREENSHOT_LATENCY=fast
# SCREENSHOT_CLEAR_CLIPBOARD=1
# SCREENSHOT_SOLVE_ALSO_LAST_ANSWER=1
# SCREENSHOT_OPENAI_BASE_URL=   # прокси OpenAI-compatible, напр. ProxyAPI

# --- STT (docs/audio-setup.md) ---
STT_PROVIDER=local
# fast | balanced | quality — без WHISPER_MODEL_SIZE: fast/balanced=small, quality=large-v3
STT_LATENCY=balanced
STT_ROLLING=1
# AUDIO_ROLLING_SEC=2
# general — HR/созвон; tech — IT, латиница без списка брендов; interview — длинный prompt
WHISPER_PROMPT_MODE=tech
WHISPER_BEAM_SIZE=3
# WHISPER_CONDITION_PREVIOUS=0
# WHISPER_PATIENCE=0
WHISPER_MODEL_SIZE=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu
WHISPER_CPU_THREADS=6
# HF_TOKEN=   # https://huggingface.co/settings/tokens
# WHISPER_BEAM_SIZE=1
# WHISPER_VAD_FILTER=0
WHISPER_GLOSSARY_FIXES=1

# STT_PROVIDER=openai
# WHISPER_MODEL=whisper-1
# OPENAI_API_KEY=sk-...

# Voice pipeline (docs/voice-pipeline.md)
# AUDIO_PRESET=call
# COPILOT_TIMING=1
# COPILOT_TIMING_JSONL=1
# STT_FINAL_DEBOUNCE_SEC=4
# STT_MIN_WORDS_FINAL_SELF=3

# --- Аудио ---
# AUDIO_SILENCE_SEC_SELF=0.85   # пауза перед STT с Brio (не резать «про Python»)
# AUDIO_MAX_SEGMENT_SEC_SELF=8
AUDIO_INPUT_INTERVIEWER=BlackHole
AUDIO_INPUT_SELF=Brio
AUDIO_ENABLE_INTERVIEWER=1
AUDIO_ENABLE_SELF=1

# --- Резюме (docs/resume-context.md) ---
# HH_ACCESS_TOKEN=
# HH_RESUME_ID=

# --- Telegram (docs/telegram-input.md) ---
# TELEGRAM_INPUT_ENABLED=1
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_IDS=123456789

# COPILOT_SESSION_WARMUP=1
