# https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_...

# --- Ответ на вопрос (⌘↩) ---
# deepseek | openai | cursor
ANSWER_PROVIDER=deepseek
DEEPSEEK_API_KEY=
# deepseek-chat = V3, быстро; deepseek-reasoner = R1, медленнее
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# OPENAI_API_KEY=sk-...          # ANSWER_PROVIDER=openai
# OPENAI_ANSWER_MODEL=gpt-4o-mini
# ANSWER_MAX_TOKENS=450
# ANSWER_REQUEST_TIMEOUT=120

# Основной UX: ответ в терминале copilot (⌘↩), не в Cursor Agents
# 1 = печатать токены по мере генерации (deepseek/openai)
TERMINAL_ANSWER_STREAM=1
# 1 = только вопрос в промпт (быстрее DeepSeek); 0 = + контекст диалога
# ANSWER_MINIMAL_CONTEXT=1
# auto = не глушить STT при ⌘↩ для deepseek/openai; always = всегда стоп
# ANSWER_PAUSE_AUDIO=auto
# 1 = реплики интервьюера в терминал после STT (во время интервью)
TERMINAL_SHOW_INTERVIEWER=1
TERMINAL_SHOW_SELF=1
# 1 = ещё открывать data/last-answer.md в Cursor
# CURSOR_OPEN_ANSWER_FILE=1

# Agents в Cursor: New Agent создаёт только пользователь.
# Опционально: UUID чата после ручного создания → CP «Привязать chatId…»
# CURSOR_AGENT_CHAT_ID=054d6e27-69ad-4692-950d-6732863ccd45
# Эксперимент: push ответа в привязанный чат (нужен chatId + `cursor` в PATH)
CURSOR_AGENT_MIRROR=0
# Устарело (sidecar не создаёт агента в UI):
# CURSOR_AGENT_AUTO_START=0
# CURSOR_AGENT_FRESH=0

# CURSOR_API_KEY — для ANSWER_PROVIDER=cursor (⌘↩ и скриншоты)
# CURSOR_MODEL=auto          # auto = ~/.cursor/cli-config.json (selectedModel)
# CURSOR_MODEL=composer-2    # или явный slug API
# CURSOR_ANSWER_CONTEXT_CHARS=800
# CURSOR_ANSWER_MINIMAL=1

# --- Скриншот ⌘⌃⇧4 → буфер → vision (см. docs/screenshot-solve.md) ---
# deepseek-chat НЕ умеет картинки: при ANSWER_PROVIDER=deepseek нужен CURSOR_API_KEY
# (auto-fallback на Cursor) или SCREENSHOT_ANSWER_PROVIDER=openai
# SCREENSHOT_SOLVE_ENABLED=1
# SCREENSHOT_LATENCY=fast         # fast: 1024px, новый агент/скрин, temp cwd; balanced — reuse
# SCREENSHOT_ANSWER_PROVIDER=cursor
# Anthropic Claude vision (быстрее Cursor SDK):
# SCREENSHOT_ANSWER_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# SCREENSHOT_ANTHROPIC_MODEL=claude-3-5-haiku-latest
# ANTHROPIC_BASE_URL=...              # опционально, прокси
# SCREENSHOT_CURSOR_MODEL=auto    # модель только для скринов; иначе = CURSOR_MODEL
# SCREENSHOT_REUSE_AGENT=0        # fast по умолчанию; 1 = resume (медленнее, но меньше create)
# SCREENSHOT_OPTIMIZE=1
# SCREENSHOT_MAX_EDGE_PX=1024
# SCREENSHOT_JPEG_QUALITY=0.78
# SCREENSHOT_WARM_AGENT=1           # прогрев SDK-агента при старте copilot
# OpenAI недоступен: cursor (выше) или прокси:
# SCREENSHOT_OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
# OPENAI_BASE_URL=...               # fallback, если SCREENSHOT_OPENAI_BASE_URL пуст
# SCREENSHOT_POLL_SEC=0.12
# SCREENSHOT_DEBOUNCE_SEC=0.08
# SCREENSHOT_SOLVE_ALSO_LAST_ANSWER=1
# SCREENSHOT_CLEAR_CLIPBOARD=1

# Фоновый прогрев при старте copilot (Whisper, OpenAI-клиент, Cursor SDK)
# COPILOT_SESSION_WARMUP=1

# --- STT (локальный Whisper по умолчанию) ---
# local (faster-whisper) | openai (Whisper API)
STT_PROVIDER=local
# Пресет задержки: fast | balanced | quality
STT_LATENCY=fast
# general — бытовая речь; interview — IT-термины в Whisper prompt (собес)
# WHISPER_PROMPT_MODE=interview
#
# fast (интервью):
#   WHISPER_MODEL_SIZE → small (если не задан явно; лучше RU, чем tiny/base)
#   AUDIO_SILENCE_SEC  → ~0.42
#   AUDIO_MAX_SEGMENT_SEC → ~3.5
#   WHISPER_VAD_FILTER → 0
# balanced: base/small, пауза ~0.55, срез ~5 с
# quality: small, пауза ~1.0, VAD в Whisper вкл, срез выкл
#
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu
# Опционально: токен https://huggingface.co/settings/tokens (быстрее скачивание, без warning в терминале)
# HF_TOKEN=hf_...
# WHISPER_MODEL_SIZE=small  # tiny/base — быстрее, хуже RU; medium — точнее, тяжелее
# WHISPER_BEAM_SIZE=1
# WHISPER_VAD_FILTER=0
WHISPER_CPU_THREADS=6       # 0 = auto; 6–8 на Apple Silicon
# WHISPER_GLOSSARY_FIXES=1  # гил→GIL, редис→Redis, …
# WHISPER_INITIAL_PROMPT=    # свой список терминов (заменяет дефолт)
# WHISPER_CONDITION_PREVIOUS=0
# AUDIO_SAMPLE_RATE=16000
# AUDIO_SILENCE_SEC=0.42
# AUDIO_MIN_SPEECH_SEC=0.25
# AUDIO_MAX_SEGMENT_SEC=3.5
# AUDIO_BLOCK_MS=50
# AUDIO_PREFER_16K=1

# Только если STT_PROVIDER=openai
# WHISPER_MODEL=whisper-1

# --- Два аудиовхода (см. docs/audio-setup.md) ---
AUDIO_INPUT_INTERVIEWER=BlackHole
AUDIO_INPUT_SELF=Brio
AUDIO_ENABLE_INTERVIEWER=1
AUDIO_ENABLE_SELF=1

# --- Telegram → [Интервьюер] (см. docs/telegram-input.md) ---
# TELEGRAM_INPUT_ENABLED=1
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_IDS=123456789
# TELEGRAM_CHAT_ID=123456789   # то же, один id
