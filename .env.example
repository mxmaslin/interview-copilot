# https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_...

# --- Ответ на вопрос (⌘↩) ---
# deepseek | openai | cursor
ANSWER_PROVIDER=deepseek
DEEPSEEK_API_KEY=
# deepseek-chat = V3, быстро; deepseek-reasoner = R1, медленнее
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# OPENAI_API_KEY=sk-...          # ANSWER_PROVIDER=openai
# OPENAI_ANSWER_MODEL=gpt-4o-mini
# ANSWER_MAX_TOKENS=450

# Основной UX: ответ в терминале copilot (⌘↩), не в Cursor Agents
# 1 = печатать токены по мере генерации (deepseek/openai)
TERMINAL_ANSWER_STREAM=1
# 1 = реплики интервьюера в терминал после STT (во время интервью)
TERMINAL_SHOW_INTERVIEWER=1
# 1 = ещё открывать data/last-answer.md в Cursor
# CURSOR_OPEN_ANSWER_FILE=1

# Agents в Cursor: New Agent создаёт только пользователь.
# Опционально: UUID чата после ручного создания → CP «Привязать chatId…»
# CURSOR_AGENT_CHAT_ID=054d6e27-69ad-4692-950d-6732863ccd45
# Эксперимент: push ответа в привязанный чат (нужен chatId + `cursor` в PATH)
CURSOR_AGENT_MIRROR=0
# Устарело (sidecar не создаёт агента в UI):
# CURSOR_AGENT_AUTO_START=0
# CURSOR_AGENT_FRESH=0

# CURSOR_API_KEY — только для ANSWER_PROVIDER=cursor (SDK)
# CURSOR_MODEL=composer-2
# CURSOR_ANSWER_CONTEXT_CHARS=800
# CURSOR_ANSWER_MINIMAL=1

# --- STT (локальный Whisper по умолчанию) ---
# local (faster-whisper) | openai (Whisper API)
STT_PROVIDER=local
# Пресет задержки: fast (default) | balanced | quality
STT_LATENCY=fast
#
# fast (интервью, минимальная задержка):
#   WHISPER_MODEL_SIZE → base (если не задан явно)
#   AUDIO_SILENCE_SEC  → ~0.42
#   AUDIO_MAX_SEGMENT_SEC → ~3.5
#   WHISPER_VAD_FILTER → 0
# balanced: base/small, пауза ~0.55, срез ~5 с
# quality: small, пауза ~1.0, VAD в Whisper вкл, срез выкл
#
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu
# WHISPER_MODEL_SIZE=base   # явно переопределяет пресет (не ставь small при STT_LATENCY=fast)
# WHISPER_BEAM_SIZE=1
# WHISPER_VAD_FILTER=0
# WHISPER_CPU_THREADS=0     # 0 = auto
# AUDIO_SAMPLE_RATE=16000
# AUDIO_SILENCE_SEC=0.42
# AUDIO_MIN_SPEECH_SEC=0.25
# AUDIO_MAX_SEGMENT_SEC=3.5
# AUDIO_BLOCK_MS=50
# AUDIO_PREFER_16K=1

# Только если STT_PROVIDER=openai
# WHISPER_MODEL=whisper-1

# --- Два аудиовхода (см. docs/audio-setup.md) ---
AUDIO_INPUT_INTERVIEWER=BlackHole
AUDIO_INPUT_SELF=Brio
AUDIO_ENABLE_INTERVIEWER=1
AUDIO_ENABLE_SELF=1
